---
export const prerender = true
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
import BaseLayout from '../layouts/BaseLayout.astro'
import { categoryColor, categoryBg, categoryLabel } from '../lib/categories'

const reader = createReader(process.cwd(), keystaticConfig)
const allPosts = await reader.collections.blog.all()

const posts = allPosts
  .filter(p => p.entry.publishedAt)
  .sort((a, b) => new Date(b.entry.publishedAt!).getTime() - new Date(a.entry.publishedAt!).getTime())

const [featured, ...rest] = posts

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('es-MX', {
    year: 'numeric', month: 'short', day: 'numeric',
  })
}
---

<BaseLayout title="Blog — Relvo">
  <div style="max-width: 780px; margin: 0 auto; padding: 0 24px 80px;">

    <!-- ── PAGE HEADER ── -->
    <div style="padding: 40px 0 32px;">
      <h1 style="
        font-family: var(--font-ui); font-size: 1.5rem; font-weight: 600;
        letter-spacing: -0.02em; color: var(--text-main); margin-bottom: 6px;
      ">
        Blog
      </h1>
      <p style="font-family: var(--font-ui); font-size: 0.9rem; color: var(--text-soft); line-height: 1.5;">
        Revenue ops, facturación y pricing para equipos B2B.
      </p>
    </div>

    <div style="border-top: 1px solid var(--border-default);" />

    {posts.length === 0 ? (
      <p style="padding: 48px 0; font-family: var(--font-ui); font-size: 0.9rem; color: var(--text-muted);">
        Próximamente — los primeros artículos están en camino.
      </p>
    ) : (
      <>
        <!-- ── FEATURED ── -->
        <div style="padding: 32px 0 28px;">
          <p style="
            font-family: var(--font-mono); font-size: 0.6rem; font-weight: 500;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: var(--text-muted); margin-bottom: 16px;
          ">Destacado</p>

          <a href={`/blog/${featured.slug}`} style="display: block;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
              <span style={`
                font-family: var(--font-mono); font-size: 0.6rem; font-weight: 500;
                letter-spacing: 0.12em; text-transform: uppercase;
                color: ${categoryColor(featured.entry.category)};
                background: ${categoryBg(featured.entry.category)};
                padding: 2px 7px; border-radius: 3px;
              `}>{categoryLabel(featured.entry.category)}</span>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted);">
                {formatDate(featured.entry.publishedAt!)}
              </span>
            </div>

            <h2 style="
              font-family: var(--font-display); font-size: 1.6rem; font-weight: 500;
              letter-spacing: -0.02em; line-height: 1.2;
              color: var(--text-main); margin-bottom: 10px;
              transition: color 0.15s;
            "
              onmouseover="this.style.color='var(--text-soft)'"
              onmouseout="this.style.color='var(--text-main)'"
            >
              {featured.entry.title}
            </h2>

            <p style="
              font-family: var(--font-ui); font-size: 0.9rem; line-height: 1.65;
              color: var(--text-soft); margin-bottom: 14px; max-width: 560px;
            ">
              {featured.entry.excerpt}
            </p>

            <span style="
              font-family: var(--font-ui); font-size: 0.8rem; font-weight: 500;
              color: var(--text-muted); transition: color 0.15s;
            "
              onmouseover="this.style.color='var(--text-main)'"
              onmouseout="this.style.color='var(--text-muted)'"
            >
              {featured.entry.author} · Leer →
            </span>
          </a>
        </div>

        <!-- ── ARTICLE GRID ── -->
        {rest.length > 0 && (
          <div style="border-top: 1px solid var(--border-default); padding-top: 24px;">
            <p style="
              font-family: var(--font-mono); font-size: 0.6rem; font-weight: 500;
              letter-spacing: 0.16em; text-transform: uppercase;
              color: var(--text-muted); margin-bottom: 16px;
            ">Todos los artículos</p>

            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
              {rest.map(post => (
                <a
                  href={`/blog/${post.slug}`}
                  style="
                    display: flex; flex-direction: column;
                    border: 1px solid var(--border-default);
                    border-radius: 4px; overflow: hidden;
                    transition: border-color 0.15s;
                    background: #fff;
                  "
                  onmouseover="this.style.borderColor='var(--border-strong)'"
                  onmouseout="this.style.borderColor='var(--border-default)'"
                >
                  <!-- Cover image -->
                  {post.entry.coverImage ? (
                    <img
                      src={post.entry.coverImage}
                      alt={post.entry.title}
                      style="width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block;"
                    />
                  ) : (
                    <div style="
                      width: 100%; aspect-ratio: 16/9;
                      background: #f6f7f8;
                      display: flex; align-items: center; justify-content: center;
                    ">
                      <img src="/logo-mark-dark.svg" alt="" style="height: 24px; opacity: 0.07;" />
                    </div>
                  )}

                  <!-- Content -->
                  <div style="padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 8px; flex: 1;">
                    <span style={`
                      font-family: var(--font-mono); font-size: 0.58rem; font-weight: 500;
                      letter-spacing: 0.1em; text-transform: uppercase;
                      color: ${categoryColor(post.entry.category)};
                      background: ${categoryBg(post.entry.category)};
                      padding: 2px 6px; border-radius: 3px;
                      width: fit-content;
                    `}>{categoryLabel(post.entry.category)}</span>

                    <span style="
                      font-family: var(--font-ui); font-size: 0.9rem; font-weight: 600;
                      color: var(--text-main); line-height: 1.35;
                    ">{post.entry.title}</span>

                    <span style="
                      font-family: var(--font-ui); font-size: 0.8rem;
                      color: var(--text-soft); line-height: 1.55;
                      display: -webkit-box; -webkit-line-clamp: 2;
                      -webkit-box-orient: vertical; overflow: hidden;
                    ">{post.entry.excerpt}</span>

                    <span style="
                      font-family: var(--font-mono); font-size: 0.62rem;
                      color: var(--text-muted); margin-top: auto; padding-top: 4px;
                    ">{post.entry.author} · {formatDate(post.entry.publishedAt!)}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>
