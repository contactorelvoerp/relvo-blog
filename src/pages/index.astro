---
export const prerender = true
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
import BaseLayout from '../layouts/BaseLayout.astro'
import { categoryColor, categoryBg, categoryLabel } from '../lib/categories'

const reader = createReader(process.cwd(), keystaticConfig)
const allPosts = await reader.collections.blog.all()

const posts = allPosts
  .filter(p => p.entry.publishedAt)
  .sort((a, b) => new Date(b.entry.publishedAt!).getTime() - new Date(a.entry.publishedAt!).getTime())

const [featured, ...rest] = posts

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('es-CL', {
    year: 'numeric', month: 'short', day: 'numeric',
  })
}
---

<BaseLayout title="Blog — Relvo">
  <div class="page-wrap">

    {posts.length === 0 ? (
      <div class="empty-state">
        <p>Próximamente — los primeros artículos están en camino.</p>
      </div>
    ) : (
      <>
        <!-- ── HERO DESTACADO ── -->
        <a href={`/blog/${featured.slug}`} class="hero-link">
          <div class="hero-card">
            {featured.entry.coverImage ? (
              <img
                src={featured.entry.coverImage}
                alt={featured.entry.title}
                class="hero-img"
              />
            ) : (
              <div class="hero-placeholder" />
            )}
            <div class="hero-overlay" />
            <div class="hero-content">
              <div class="hero-meta">
                <span
                  class="cat-badge"
                  style={`color: ${categoryColor(featured.entry.category)}; background: ${categoryBg(featured.entry.category)};`}
                >
                  {categoryLabel(featured.entry.category)}
                </span>
                <span class="hero-date">{formatDate(featured.entry.publishedAt!)}</span>
              </div>
              <h2 class="hero-title">{featured.entry.title}</h2>
              <p class="hero-excerpt">{featured.entry.excerpt}</p>
              <p class="hero-author">por {featured.entry.author}</p>
            </div>
          </div>
        </a>

        <!-- ── GRID ── -->
        {rest.length > 0 && (
          <div class="grid-section">
            <div class="post-grid">
              {rest.map(post => (
                <a href={`/blog/${post.slug}`} class="post-card">
                  <div class="card-img-wrap">
                    {post.entry.coverImage ? (
                      <img
                        src={post.entry.coverImage}
                        alt={post.entry.title}
                        class="card-img"
                      />
                    ) : (
                      <div class="card-placeholder">
                        <img src="/logo-mark-dark.svg" alt="" class="card-placeholder-logo" />
                      </div>
                    )}
                  </div>
                  <div class="card-body">
                    <p class="card-author">por {post.entry.author}</p>
                    <h3 class="card-title">{post.entry.title}</h3>
                    <p class="card-excerpt">{post.entry.excerpt}</p>
                    <div class="card-footer">
                      <span
                        class="cat-badge"
                        style={`color: ${categoryColor(post.entry.category)}; background: ${categoryBg(post.entry.category)};`}
                      >
                        {categoryLabel(post.entry.category)}
                      </span>
                      <span class="card-date">{formatDate(post.entry.publishedAt!)}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    )}

  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 32px 24px 100px;
  }

  /* ---- Empty state ---- */
  .empty-state {
    padding: 80px 0;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* ---- Hero ---- */
  .hero-link {
    display: block;
    text-decoration: none;
    margin-bottom: 48px;
  }
  .hero-card {
    position: relative;
    width: 100%;
    aspect-ratio: 21/9;
    border-radius: 12px;
    overflow: hidden;
    background: var(--text-main);
  }
  @media (max-width: 640px) {
    .hero-card { aspect-ratio: 4/3; border-radius: 8px; }
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .hero-link:hover .hero-img {
    transform: scale(1.02);
  }
  .hero-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #13131E 0%, #2a1f4a 100%);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,18,0.85) 0%,
      rgba(10,10,18,0.4) 45%,
      rgba(10,10,18,0.05) 100%
    );
  }
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 2.5rem;
  }
  @media (max-width: 640px) {
    .hero-content { padding: 1.25rem; }
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .hero-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255,255,255,0.55);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #fff;
    margin: 0 0 10px;
    max-width: 720px;
  }
  .hero-excerpt {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin: 0 0 14px;
    max-width: 560px;
  }
  @media (max-width: 640px) {
    .hero-excerpt { display: none; }
  }
  .hero-author {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  /* ---- Category badge (shared) ---- */
  .cat-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 3px;
    white-space: nowrap;
  }

  /* ---- Grid ---- */
  .grid-section {
    border-top: 1px solid var(--border-default);
    padding-top: 40px;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 900px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 560px) {
    .post-grid { grid-template-columns: 1fr; gap: 16px; }
  }

  /* ---- Post card ---- */
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.7);
    border: 1px solid var(--border-default);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .post-card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 4px 20px rgba(19,19,30,0.07);
  }
  .card-img-wrap {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: #f0f0f3;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .post-card:hover .card-img {
    transform: scale(1.04);
  }
  .card-placeholder {
    width: 100%;
    height: 100%;
    background: #f0f0f3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-placeholder-logo {
    height: 28px;
    opacity: 0.07;
  }
  .card-body {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .card-author {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--text-muted);
    margin: 0;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--text-main);
    margin: 0;
  }
  .card-excerpt {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--brand-morado);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 8px;
  }
  .card-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-left: auto;
  }
</style>
