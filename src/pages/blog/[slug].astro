---
export const prerender = true
import { createReader } from '@keystatic/core/reader'
import { DocumentRenderer } from '@keystatic/core/renderer'
import keystaticConfig from '../../../keystatic.config'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { categoryColor, categoryBg, categoryLabel } from '../../lib/categories'

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig)
  const all = await reader.collections.blog.all()
  const sorted = all
    .filter(p => p.entry.publishedAt)
    .sort((a, b) => new Date(b.entry.publishedAt!).getTime() - new Date(a.entry.publishedAt!).getTime())

  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      prev: sorted[i + 1] ? { slug: sorted[i + 1].slug, title: sorted[i + 1].entry.title } : null,
      next: sorted[i - 1] ? { slug: sorted[i - 1].slug, title: sorted[i - 1].entry.title } : null,
    },
  }))
}

const { slug } = Astro.params
const { prev, next } = Astro.props

const reader = createReader(process.cwd(), keystaticConfig)
const post = await reader.collections.blog.read(slug!)
if (!post) return Astro.redirect('/404')

const content = await post.content()

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('es-MX', {
    year: 'numeric', month: 'long', day: 'numeric',
  })
}
---

<BaseLayout
  title={`${post.title} | Relvo Blog`}
  description={post.excerpt}
  image={post.coverImage ?? undefined}
>

  <!-- ── COVER IMAGE (Notion style — full bleed) ── -->
  {post.coverImage && (
    <div class="cover-wrap">
      <img src={post.coverImage} alt={post.title} class="cover-img" />
    </div>
  )}

  <!-- ── ARTICLE HEADER ── -->
  <div class={`article-header ${post.coverImage ? 'has-cover' : ''}`}>
    <div class="header-inner">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/" class="breadcrumb-link">Blog</a>
        <span>›</span>
        <span
          class="cat-badge"
          style={`color: ${categoryColor(post.category)}; background: ${categoryBg(post.category)};`}
        >
          {categoryLabel(post.category)}
        </span>
      </div>

      <!-- Title -->
      <h1 class="post-title">{post.title}</h1>

      <!-- Excerpt / deck -->
      {post.excerpt && (
        <p class="post-excerpt">{post.excerpt}</p>
      )}

      <!-- Byline -->
      <div class="byline">
        <span>{post.author}</span>
        {post.publishedAt && (
          <>
            <span class="byline-dot">·</span>
            <span>{formatDate(post.publishedAt)}</span>
          </>
        )}
      </div>

    </div>
  </div>

  <!-- ── ARTICLE BODY ── -->
  <article style="max-width: 680px; margin: 0 auto; padding: 44px 1.5rem 0;">
    <div class="prose-relvo">
      <DocumentRenderer document={content} />
    </div>
  </article>

  <!-- ── POST NAVIGATION ── -->
  <nav style="max-width: 680px; margin: 56px auto 0; padding: 24px 1.5rem; border-top: 1px solid var(--border-default);">
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 24px;">

      {prev ? (
        <a href={`/blog/${prev.slug}`} style="flex: 1; transition: color 0.15s;"
          onmouseover="this.querySelector('span:last-child').style.color='var(--text-main)'"
          onmouseout="this.querySelector('span:last-child').style.color='var(--text-soft)'"
        >
          <span style="display: block; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px;">← Anterior</span>
          <span style="display: block; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 500; color: var(--text-soft); line-height: 1.3; transition: color 0.15s;">{prev.title}</span>
        </a>
      ) : <div style="flex:1" />}

      <a href="/" style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; transition: color 0.15s; flex-shrink: 0;"
        onmouseover="this.style.color='var(--text-soft)'"
        onmouseout="this.style.color='var(--text-muted)'"
      >
        ↑ Blog
      </a>

      {next ? (
        <a href={`/blog/${next.slug}`} style="flex: 1; text-align: right; transition: color 0.15s;"
          onmouseover="this.querySelector('span:last-child').style.color='var(--text-main)'"
          onmouseout="this.querySelector('span:last-child').style.color='var(--text-soft)'"
        >
          <span style="display: block; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px;">Siguiente →</span>
          <span style="display: block; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 500; color: var(--text-soft); line-height: 1.3; transition: color 0.15s;">{next.title}</span>
        </a>
      ) : <div style="flex:1" />}

    </div>
  </nav>

</BaseLayout>

<style>
  /* ── Cover image ── */
  .cover-wrap {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    display: block;
  }
  .cover-img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    display: block;
  }

  /* ── Article header ── */
  .article-header {
    padding: 48px 1.5rem 44px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .article-header.has-cover {
    padding-top: 36px;
  }
  .header-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 28px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .breadcrumb-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb-link:hover { color: var(--text-soft); }
  .cat-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
  }

  /* Title */
  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.8rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text-main);
    margin: 0 0 16px;
  }

  /* Excerpt */
  .post-excerpt {
    font-family: var(--font-ui);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--text-soft);
    margin: 0 0 20px;
  }

  /* Byline */
  .byline {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .byline-dot { color: var(--border-strong); }
</style>
