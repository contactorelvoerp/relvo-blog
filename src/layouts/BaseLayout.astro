---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  image?: string
}

const {
  title,
  description = 'Blog de Relvo — Revenue ops, facturación y operaciones comerciales B2B.',
  image,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://blog.relvoerp.com')
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Playfair+Display:wght@500;600&display=swap" rel="stylesheet" />
  </head>

  <body>

    <!-- Background gradient orbs -->
    <div class="bg-orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <!-- Navbar -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo-link">
          <img src="/logo-mark-dark.svg" alt="" aria-hidden="true" class="logo-mark" />
          <img src="/relvo-wordmark-dark.svg" alt="Relvo" class="logo-wordmark" />
          <span class="blog-badge">Blog</span>
        </a>
        <a href="https://relvoerp.com" class="back-link">relvoerp.com →</a>
      </div>
    </header>

    <main style="padding-top: 56px;">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-shell">
        <div class="footer-card">

          <a
            href="https://www.linkedin.com/company/relvoerp/posts/?feedView=all"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Relvo en LinkedIn"
            class="linkedin-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
              <rect width="24" height="24" rx="3" fill="#0A66C2" />
              <path
                d="M8.94 7.44a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0zM6.3 9.36h2.76v9.24H6.3V9.36zm4.44 0h2.64v1.26h.04c.37-.7 1.27-1.44 2.61-1.44 2.79 0 3.31 1.83 3.31 4.21v5.21h-2.76v-4.62c0-1.1-.02-2.52-1.54-2.52-1.54 0-1.78 1.2-1.78 2.44v4.7h-2.76V9.36z"
                fill="#ffffff"
              />
            </svg>
          </a>

          <div class="footer-grid">

            <!-- Brand -->
            <div class="footer-brand">
              <div class="footer-logo">
                <img src="/logo-mark-dark.svg" alt="" aria-hidden="true" class="footer-logo-mark" />
                <img src="/relvo-wordmark-dark.svg" alt="Relvo" class="footer-logo-wordmark" />
              </div>
              <p class="footer-tagline">Infraestructura de ingresos B2B para LATAM</p>
              <p class="footer-copy">© {new Date().getFullYear()} Relvo. Todos los derechos reservados.</p>
            </div>

            <!-- Columnas de nav -->
            <div class="footer-cols">
              <div class="footer-col">
                <p class="col-title">Páginas</p>
                <div class="col-links">
                  <a href="https://relvoerp.com">Inicio</a>
                  <a href="https://relvoerp.com/about-us">Nosotros</a>
                  <a href="https://relvoerp.com/precios">Precios</a>
                  <a href="https://relvoerp.com/docs">Docs</a>
                  <a href="/">Blog</a>
                </div>
              </div>
              <div class="footer-col">
                <p class="col-title">Demo</p>
                <div class="col-links">
                  <a href="https://calendar.app.google/GbBM26VivFQHGzyL9" target="_blank" rel="noopener noreferrer">Agendar reunión</a>
                  <a href="https://relvoerp.com/#contacto">Contactar</a>
                </div>
              </div>
              <div class="footer-col">
                <p class="col-title">Contacto</p>
                <div class="col-links">
                  <a href="mailto:contacto@relvoerp.com">contacto@relvoerp.com</a>
                  <p class="footer-address">San Patricio 4264,<br />Vitacura, Santiago, Chile</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ---- Gradient orbs background ---- */
  .bg-orbs {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }
  .orb-1 {
    top: -15%;
    left: -10%;
    width: 55%;
    height: 55%;
    background: radial-gradient(circle, rgba(208,255,11,0.14) 0%, transparent 70%);
  }
  .orb-2 {
    top: 30%;
    right: -15%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, rgba(99,59,242,0.09) 0%, transparent 70%);
  }
  .orb-3 {
    bottom: 5%;
    left: 15%;
    width: 45%;
    height: 45%;
    background: radial-gradient(circle, rgba(255,149,102,0.10) 0%, transparent 70%);
  }

  /* ---- Header ---- */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .header-inner {
    max-width: 82rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .logo-mark,
  .logo-wordmark {
    height: 20px;
    width: auto;
  }
  @media (min-width: 640px) {
    .logo-mark,
    .logo-wordmark {
      height: 24px;
    }
  }
  .blog-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(19,19,30,0.07);
    color: var(--text-soft);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .back-link {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--text-main); }

  /* ---- Footer ---- */
  .site-footer {
    padding: 4rem 1rem 2.5rem;
    margin-top: 80px;
  }
  @media (min-width: 640px) {
    .site-footer { padding: 5rem 1.5rem 2.5rem; }
  }
  @media (min-width: 768px) {
    .site-footer { padding: 7rem 1.5rem 2.5rem; }
  }
  .footer-shell {
    max-width: 82rem;
    margin: 0 auto;
  }
  .footer-card {
    position: relative;
    border-radius: 0.75rem;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(19,19,30,0.06);
    padding: 2rem 1.25rem;
  }
  @media (min-width: 640px) {
    .footer-card { padding: 2.5rem 2rem; }
  }
  @media (min-width: 768px) {
    .footer-card { padding: 3.5rem 3rem; }
  }
  .linkedin-icon {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    display: inline-block;
    transition: transform 0.15s;
  }
  .linkedin-icon:hover { transform: scale(1.05); }
  @media (min-width: 640px) {
    .linkedin-icon { top: 2rem; right: 2rem; }
  }
  @media (min-width: 768px) {
    .linkedin-icon { top: 2.5rem; right: 3rem; }
  }
  .footer-grid {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: 1.2fr 1.8fr; align-items: start; }
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-logo-mark,
  .footer-logo-wordmark {
    height: 20px;
    width: auto;
  }
  @media (min-width: 640px) {
    .footer-logo-mark,
    .footer-logo-wordmark {
      height: 24px;
    }
  }
  .footer-tagline {
    margin-top: 1rem;
    max-width: 18rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-soft);
  }
  .footer-copy {
    margin-top: 1rem;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .footer-cols { grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  }
  .col-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .col-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .col-links a {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  .col-links a:hover { color: var(--text-main); }
  .footer-address {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-muted);
    padding-top: 0.25rem;
    margin: 0;
  }
</style>
